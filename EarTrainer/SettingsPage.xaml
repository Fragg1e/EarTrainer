<Page x:Class="EarTrainer.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:EarTrainer"
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="800"
      Title="SettingsPage">
    <Grid Background="{StaticResource SettingsBackground}">
        <Label Content="Settings" Style="{StaticResource TitleStyle}" Margin="0,20,0,0" FontSize="42"/>
        <Button x:Name="Return_To_Menu" Content="Main Menu" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Margin="29,27,0,0" VerticalAlignment="Top" Width="120" Height="59" Click="Return_To_Menu_Click"/>
        <Label Content="Difficulty" Style="{StaticResource TextStyle}" HorizontalAlignment="Left" Margin="99,170,0,0" VerticalAlignment="Top" FontSize="36"/>
        <StackPanel Margin="335,115,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
            <RadioButton x:Name="EasyRadioButton" Content="Easy" Style="{StaticResource SettingsRadioButtonStyle}" GroupName="DifficultyGroup" Checked="Difficulty_Checked"/>
            <RadioButton x:Name="MediumRadioButton" Content="Medium" Style="{StaticResource SettingsRadioButtonStyle}" GroupName="DifficultyGroup" Checked="Difficulty_Checked"/>
            <RadioButton x:Name="HardRadioButton" Content="Hard" Style="{StaticResource SettingsRadioButtonStyle}" GroupName="DifficultyGroup" Checked="Difficulty_Checked"/>
        </StackPanel>
        <Label Content="Volume" Style="{StaticResource TextStyle}" HorizontalAlignment="Left" Margin="99,350,0,0" VerticalAlignment="Top" FontSize="36"/>
        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="50" Width="250" Height="40" HorizontalAlignment="Left" Margin="335,375,0,0" VerticalAlignment="Top" ValueChanged="VolumeSlider_ValueChanged"/>
        <TextBlock x:Name="VolumeTextBlock" Text="50%" Style="{StaticResource BodyTextStyle}" FontSize="24" Margin="600,370,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        
    </Grid>
</Page>
