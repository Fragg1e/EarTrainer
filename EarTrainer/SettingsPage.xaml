<Page x:Class="EarTrainer.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EarTrainer"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="SettingsPage">

    <Grid Background="#FF373333">
        <Label Content="Settings"
               HorizontalAlignment="Center"
               Margin="0,20,0,0"
               VerticalAlignment="Top"
               FontSize="42"
               Foreground="White"
               FontWeight="Bold"/>

        <Button x:Name="Return_To_Menu"
                Content="Main Menu"
                HorizontalAlignment="Left"
                Margin="29,27,0,0"
                VerticalAlignment="Top"
                Height="59"
                Width="116"
                FontSize="20"
                Click="Return_To_Menu_Click"/>

        <Label Content="Difficulty"
               HorizontalAlignment="Left"
               Margin="99,110,0,0"
               VerticalAlignment="Top"
               FontSize="36"
               Foreground="White"
               FontWeight="Bold"/>

        <StackPanel Margin="335,115,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
            <RadioButton x:Name="EasyRadioButton"
                         Content="Easy"
                         GroupName="DifficultyGroup"
                         Foreground="White"
                         FontSize="26"
                         Margin="0,6,0,6"
                         Checked="Difficulty_Checked"/>

            <RadioButton x:Name="MediumRadioButton"
                         Content="Medium"
                         GroupName="DifficultyGroup"
                         Foreground="White"
                         FontSize="26"
                         Margin="0,6,0,6"
                         Checked="Difficulty_Checked"/>

            <RadioButton x:Name="HardRadioButton"
                         Content="Hard"
                         GroupName="DifficultyGroup"
                         Foreground="White"
                         FontSize="26"
                         Margin="0,6,0,6"
                         Checked="Difficulty_Checked"/>
        </StackPanel>

        <Label Content="Volume"
               HorizontalAlignment="Left"
               Margin="99,255,0,0"
               VerticalAlignment="Top"
               FontSize="36"
               Foreground="White"
               FontWeight="Bold"/>

        <Slider x:Name="VolumeSlider"
                Minimum="0"
                Maximum="100"
                Value="50"
                Width="250"
                Height="40"
                HorizontalAlignment="Left"
                Margin="335,262,0,0"
                VerticalAlignment="Top"
                ValueChanged="VolumeSlider_ValueChanged"/>

        <TextBlock x:Name="VolumeTextBlock"
                   Text="50%"
                   Foreground="White"
                   FontSize="24"
                   Margin="600,262,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <Label Content="Questions"
               HorizontalAlignment="Left"
               Margin="99,345,0,0"
               VerticalAlignment="Top"
               FontSize="36"
               Foreground="White"
               FontWeight="Bold"/>

        <Slider x:Name="QuestionCountSlider"
                Minimum="3"
                Maximum="20"
                Value="10"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                Width="250"
                Height="40"
                HorizontalAlignment="Left"
                Margin="335,352,0,0"
                VerticalAlignment="Top"
                ValueChanged="QuestionCountSlider_ValueChanged"/>

        <TextBlock x:Name="QuestionCountTextBlock"
                   Text="10"
                   Foreground="White"
                   FontSize="24"
                   Margin="600,352,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>
    </Grid>
</Page>