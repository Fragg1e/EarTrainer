<Page x:Class="EarTrainer.HighScoresPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:EarTrainer"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HighScoresPage">
    <Grid Background="{StaticResource Background}">
        <Label Content="High Scores" Style="{StaticResource TitleStyle}" Margin="0,20,0,0" FontSize="40"/>
        
        <Button x:Name="Return_To_Menu" Content="Main Menu" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,20,0,0" Click="Return_To_Menu_Click"/>
        
        <DataGrid x:Name="HighScoresDataGrid" Margin="40,100,40,40" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Player" Binding="{Binding PlayerName}"/>
                <DataGridTextColumn Header="Score" Binding="{Binding Score}"/>
                <DataGridTextColumn Header="Difficulty" Binding="{Binding Difficulty}"/>
                <DataGridTextColumn Header="Date" Binding="{Binding DatePlayedDisplay}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
