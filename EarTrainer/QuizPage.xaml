<Page x:Class="EarTrainer.QuizPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EarTrainer"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="QuizPage">

    <Grid Background="#FF1C1427">
        <Label x:Name="TitleLabel"
               Content="Interval Quiz"
               HorizontalAlignment="Center"
               Margin="0,10,0,0"
               VerticalAlignment="Top"
               FontSize="45"
               Foreground="White"/>

        <TextBlock x:Name="QuestionNumberText"
                   Foreground="White"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   Margin="0,80,0,0"
                   VerticalAlignment="Top"/>

        <Button x:Name="ReplayButton"
                Content="Play Sound Again"
                HorizontalAlignment="Center"
                Margin="0,140,0,0"
                VerticalAlignment="Top"
                Height="50"
                Width="160"
                Click="ReplayButton_Click"/>

        <UniformGrid Rows="2" Columns="2"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     Margin="0,240,0,0"
                     Width="500"
                     Height="180">

            <Button x:Name="AnswerButton1" Click="AnswerButton_Click" FontSize="18" Margin="10"/>
            <Button x:Name="AnswerButton2" Click="AnswerButton_Click" FontSize="18" Margin="10"/>
            <Button x:Name="AnswerButton3" Click="AnswerButton_Click" FontSize="18" Margin="10"/>
            <Button x:Name="AnswerButton4" Click="AnswerButton_Click" FontSize="18" Margin="10"/>
        </UniformGrid>

        <TextBlock x:Name="FeedbackText"
                   Foreground="White"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   Margin="0,203,0,0"
                   VerticalAlignment="Top"/>

        <TextBlock x:Name="Score"
            Foreground="White"
            FontSize="20"
            HorizontalAlignment="Left"
            Margin="648,137,0,0"
            VerticalAlignment="Top" Width="119" Height="53"/>

        <TextBlock x:Name="NamePromptText"
                   Foreground="White"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   Margin="0,255,0,0"
                   VerticalAlignment="Top"
                   Visibility="Collapsed"
                   Text="Enter your name to save your score"/>

        <TextBox x:Name="PlayerNameTextBox"
                 HorizontalAlignment="Center"
                 Margin="0,290,0,0"
                 VerticalAlignment="Top"
                 Width="220"
                 Height="35"
                 FontSize="18"
                 Visibility="Collapsed"/>

        <Button x:Name="SaveScoreButton"
                Content="Save Score"
                HorizontalAlignment="Center"
                Margin="0,340,0,0"
                VerticalAlignment="Top"
                Width="140"
                Height="40"
                FontSize="18"
                Visibility="Collapsed"
                Click="SaveScoreButton_Click"/>


        <Button x:Name="Return_To_Menu"
                Content="Main Menu"
                HorizontalAlignment="Left"
                Margin="20,20,0,0"
                VerticalAlignment="Top"
                Height="50"
                Width="120"
                FontSize="18"
                Click="Return_To_Menu_Click"/>
    </Grid>
</Page>
