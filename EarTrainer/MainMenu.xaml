<Page x:Class="EarTrainer.MainMenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:EarTrainer"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainMenu">
    <Grid Background="{StaticResource Background}">
        <Grid.ColumnDefinitions>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
        </Grid.RowDefinitions>
        <Frame x:Name="MenuFrame" NavigationUIVisibility="Hidden"/>
        <Label Content="Ear Trainer" Style="{StaticResource TitleStyle}" Margin="0,40,0,0" Height="80" Width="400" FontFamily="Bahnschrift Light" FontSize="75"/>
        <Button x:Name="StartBtn" Content="Start" Style="{StaticResource MenuButtonStyle}" HorizontalAlignment="Left" Margin="48,275,0,0" VerticalAlignment="Top" Panel.ZIndex="5" Click="StartBtn_Click"/>
        <Button x:Name="HighScoresBtn" Content="Leaderboard" Style="{StaticResource MenuButtonStyle}" HorizontalAlignment="Center" Margin="0,275,0,0" VerticalAlignment="Top" Panel.ZIndex="5" Click="HighScoresBtn_Click" FontSize="30"/>
        <Button x:Name="SettingsBtn" Content="Settings" Style="{StaticResource MenuButtonStyle}" HorizontalAlignment="Left" Margin="560,275,0,0" VerticalAlignment="Top" Panel.ZIndex="5" Click="SettingsBtn_Click"/>
    </Grid>
</Page>
